{
  "manifest_version": 3,
  "name": "Vue Grab",
  "version": "3.0.0",
  "description": "Click any Vue component to extract its context with Pinia, Vuex, TanStack Query, Vue Router support for AI coding assistants",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "downloads",
    "storage"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "css": ["src/content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/injected.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
